<mujoco model="point_reacher">
  <option timestep="0.01" gravity="0 0 0" integrator="RK4"/>

  <visual>
    <headlight ambient="0.35 0.35 0.35" diffuse="0.75 0.75 0.75" specular="0.15 0.15 0.15"/>
    <map znear="0.01"/>
    <global azimuth="135" elevation="-35"/>
  </visual>

  <default>
    <joint damping="1.0" armature="0.05" limited="true"/>
    <geom friction="0.4 0.005 0.0001" rgba="0.18 0.44 0.82 1"/>
    <motor ctrllimited="true" ctrlrange="-1 1"/>
  </default>

  <worldbody>
    <light pos="0 0 2.5" dir="0 0 -1"/>
    <geom name="floor" type="plane" size="2 2 0.1" rgba="0.96 0.96 0.96 1"/>

    <body name="point" pos="0 0 0.06">
      <joint name="slide_x" type="slide" axis="1 0 0" range="-1 1"/>
      <joint name="slide_y" type="slide" axis="0 1 0" range="-1 1"/>
      <geom name="agent" type="sphere" size="0.06" mass="0.2"/>
      <site name="agent_site" type="sphere" size="0.07" rgba="0.18 0.44 0.82 0.18"/>
    </body>

    <body name="target" pos="0.55 0.55 0.06">
      <geom
        name="target_geom"
        type="sphere"
        size="0.05"
        contype="0"
        conaffinity="0"
        mass="0.0001"
        rgba="0.92 0.24 0.18 0.95"
      />
      <site name="target_site" type="sphere" size="0.065" rgba="0.92 0.24 0.18 0.18"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="x_motor" joint="slide_x" gear="1"/>
    <motor name="y_motor" joint="slide_y" gear="1"/>
  </actuator>
</mujoco>
